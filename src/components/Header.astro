---
import { Icon } from "astro-icon/components";
import * as about from "../pages/about/about.md";
---

<header class="mx-auto pt-4 pb-2 sm:pt-6 sm:pb-2 relative">
  <article
    class="flex flex-col items-center gap-3 sm:gap-4 w-full max-w-2xl px-2"
  >
    <div
      class="flex-shrink-0 w-16 sm:w-20 md:w-24 rounded-full shadow-sm overflow-hidden"
    >
      <img
        src="/profile_pic.jpg"
        alt="Vidura Gunawardana profile picture"
        class="grayscale-[50] hover:grayscale-0 w-16 sm:w-20 md:w-24 h-16 sm:h-20 md:h-24 rounded-full object-cover"
        width="192"
        height="192"
        loading="eager"
      />
    </div>

    <div class="text-center">
      <div
        class="flex flex-col sm:flex-row justify-center items-center mb-2 relative"
      >
        <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight relative">
          {about.frontmatter.name}
          <div class="absolute top-0 left-full ml-1 sm:ml-2 -mt-3 sm:-mt-4">
            <div class="badge w-max text-xs sm:text-sm font-light badge-outline shadow-lg">
              {about.frontmatter.pronouns}
            </div>
          </div>
        </h1>
      </div>
      <h2 class="text-base sm:text-lg mb-2 text-secondary">
        {about.frontmatter.designation}
      </h2>
      <div class="flex items-center justify-center mt-1">
        <Icon name="carbon:location" class="w-3 h-3 sm:w-4 sm:h-4 mr-1" />
        <p class="text-xs sm:text-sm text-secondary">{about.frontmatter.location}</p>
      </div>
    </div>
  </article>
</header>
